{
  "applicationId": "com.naosim.workbartimer",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "port": 0,
  "modes": {
    "window": {
      "title": "Work Bar Timer",
      "width": 380,
      "height": 402,
      "minWidth": 300,
      "minHeight": 380,
      "resizable": true,
      "alwaysOnTop": true,
      "borderless": true,
      "transparent": true,
      "enableInspector": true
    }
  },
  "enableExtensions": true,
  "extensions": [
    {
      "id": "js.neutralino.timerapi",
      "command": "node ${NL_PATH}/extensions/timer-api/index.js"
    }
  ],
  "nativeAllowList": [
    "app.*",
    "window.*",
    "os.*",
    "filesystem.*",
    "events.*",
    "extensions.*"
  ],
  "cli": {
    "resourcesPath": "/dist/",
    "clientLibrary": "/dist/neutralino.js",
    "binaryName": "WorkBarTimer",
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0"
  }
}